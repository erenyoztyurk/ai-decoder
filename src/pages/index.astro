---
import MainLayout from '../layouts/MainLayout.astro';

// Astro.glob yerine Vite'ın daha sağlam olan import.meta.glob yöntemini kullanıyoruz
const posts = import.meta.glob('./*.md', { eager: true });
const allPosts = Object.values(posts);

// Tarihe göre sıralama (Frontmatter içinde date yoksa hata vermemesi için korumalı)
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date || 0).getTime();
  const dateB = new Date(b.frontmatter.date || 0).getTime();
  return dateB - dateA;
});
---

<MainLayout 
	title="AI Decoder | Latest AI Guides & Reviews" 
	description="Discover the latest in Artificial Intelligence, from tools like Mythos AI to deep dives into Llama 3 and GPT-5.">
	
	<p style="color: #666; margin-bottom: 2rem;">Explore our latest technical guides and AI industry insights.</p>

	<div class="post-list">
		{sortedPosts.map(post => (
			<a href={post.url} class="post-card">
				<div class="post-content">
					<h2>{post.frontmatter.title}</h2>
					<p>{post.frontmatter.description}</p>
					<span class="read-more">Read Guide →</span>
				</div>
			</a>
		))}
	</div>

	<style>
		.post-list { display: grid; gap: 2rem; }
		.post-card { 
			display: block; 
			text-decoration: none; 
			color: inherit; 
			padding: 1.5rem; 
			border: 1px solid #eee; 
			border-radius: 12px; 
			transition: all 0.3s ease;
			background: white;
		}
		.post-card:hover { 
			border-color: #0070f3; 
			transform: translateY(-3px); 
			box-shadow: 0 10px 20px rgba(0,0,0,0.05); 
		}
		h2 { margin: 0 0 0.5rem 0; font-size: 1.5rem; color: #111; line-height: 1.2; }
		p { margin: 0 0 1.2rem 0; color: #444; font-size: 1rem; line-height: 1.5; }
		.read-more { color: #0070f3; font-weight: 700; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px; }
	</style>
</MainLayout>